{
  "name": "todo",
  "version": "0.1.0",
  "instructions": "Use todo_* tools to operate this app.",
  "handler": {
    "command": "python",
    "args": ["./todo_handlers.py"]
  },
  "tools": [
    {
      "name": "todo_status",
      "description": "Return app status.",
      "mutation": "never",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      }
    },
    {
      "name": "todo_create",
      "description": "Create a todo item.",
      "mutation": "always",
      "inputSchema": {
        "type": "object",
        "properties": {
          "title": { "type": "string" }
        },
        "required": ["title"],
        "additionalProperties": false
      }
    }
  ]
}
